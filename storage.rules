rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Invoice PDFs: public read, authenticated owner write
    match /invoices/{ownerId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }

    // User assets (logo, UPI QR): public read, owner write
    match /users/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
