rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Invoice PDFs: owner read/write only.
    // Shared invoice links must use signed download URLs (time-limited),
    // not rely on broad authenticated-read here.
    match /invoices/{ownerId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;
    }

    // User assets (logo, UPI QR): owner read/write only.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
