rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Invoice PDFs: owner-only read/write
    match /invoices/{ownerId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == ownerId;
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }

    // User assets (logo, UPI QR): owner-only read/write
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
